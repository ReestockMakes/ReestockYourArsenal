<Defs>

  <!--Nerve blowgun-->

  <ThingDef ParentName="BaseWeaponNeolithic">
    <defName>Reestock_NerveBlowgun</defName>
    <label>nerve blowgun</label>
    <description>A very simple ranged weapon that works by the user blowing air through a thin shaft to launch a projectile. It's loaded with paralytic biotoxin darts that stun non-mechanoid targets, but doesn't do much physical damage.</description>
    <possessionCount>1</possessionCount>
    <graphicData>
      <texPath>Things/Item/Equipment/WeaponRanged/NerveBlowgun</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>0.9</drawSize>
    </graphicData>
    <soundInteract>Bow_Small</soundInteract>
    <recipeMaker />
    <costList>
      <WoodLog>30</WoodLog>
    </costList>
    <statBases>
      <WorkToMake>2400</WorkToMake>
      <Mass>0.8</Mass>
      <AccuracyTouch>0.75</AccuracyTouch>
      <AccuracyShort>0.65</AccuracyShort>
      <AccuracyMedium>0.45</AccuracyMedium>
      <AccuracyLong>0.25</AccuracyLong>
      <RangedWeapon_Cooldown>2</RangedWeapon_Cooldown>
    </statBases>
    <weaponTags>
      <li>NeolithicRangedBasic</li>
    </weaponTags>
    <weaponClasses>
      <li>Ranged</li>
      <li>RangedLight</li>
    </weaponClasses>
    <recipeMaker>
      <recipeUsers>
        <li>CraftingSpot</li>
      </recipeUsers>
      <skillRequirements>
        <Crafting>3</Crafting>
      </skillRequirements>
    </recipeMaker>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>Reestock_Arrow_NerveDart</defaultProjectile>
        <warmupTime>1.35</warmupTime>
        <range>19.9</range>
        <soundCast>Reestock_Shot_NerveBlowgun</soundCast>
      </li>
    </verbs>
    <tools>
      <li>
        <label>shaft</label>
        <capacities>
          <li>Blunt</li>
          <li>Poke</li>
        </capacities>
        <power>9</power>
        <cooldownTime>2</cooldownTime>
      </li>
    </tools>
  </ThingDef>

  <ThingDef ParentName="BaseProjectileNeolithic">
    <defName>Reestock_Arrow_NerveDart</defName>
    <label>nerve dart</label>
    <graphicData>
      <texPath>Things/Projectile/Arrow_NerveDart</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <projectile>
      <damageDef>Nerve</damageDef>
      <damageAmountBase>2</damageAmountBase>
      <speed>44</speed>
    </projectile>
  </ThingDef>
</Defs>
